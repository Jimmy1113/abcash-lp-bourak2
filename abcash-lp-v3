<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>暴落時の買い増し戦略、知っていますか？｜ABCash 無料体験会</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Shippori+Mincho:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --tq:#25B2C7;--tql:#60C7D5;--tqp:#E8F8FA;
  --tb:#2F3842;--stone:#596572;--og:#F77261;
  --wh:#FFFFFF;--iv:#F8F6ED;--bd:#EBEBEB;
  --mint:#42B187;--yellow:#E5EB67
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Noto Sans JP',sans-serif;color:var(--tb);background:var(--wh);line-height:1.8;overflow-x:hidden}
img{max-width:100%}

/* ── UTIL ── */
.sec{padding:64px 20px}
.sec-iv{background:var(--iv)}
.sec-wh{background:var(--wh)}
.sec-dk{background:var(--tb)}
.si{max-width:640px;margin:0 auto}
.lbl{font-size:10px;letter-spacing:.16em;color:var(--tq);font-weight:500;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.lbl::before{content:'';width:18px;height:1px;background:var(--tq)}
.lbl-wh{color:var(--tql)}
.lbl-wh::before{background:var(--tql)}
h2.sh{font-family:'Shippori Mincho',serif;font-size:clamp(22px,5.5vw,34px);font-weight:500;line-height:1.5;margin-bottom:28px}
h2.sh-wh{color:var(--wh)}
.ac{color:var(--tql)}
.og{color:var(--og)}
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.fade-in{opacity:0;transform:translateY(16px);transition:opacity .5s ease,transform .5s ease}
.fade-in.vis{opacity:1;transform:translateY(0)}

/* ── 1. CAMPAIGN BANNER ── */
.campaign-banner{background:var(--og);padding:14px 20px;text-align:center;position:relative}
.cb-in{max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:4px;align-items:center}
.cb-tag{display:inline-block;background:rgba(255,255,255,.25);border-radius:20px;font-size:10px;font-weight:500;color:var(--wh);padding:2px 10px;letter-spacing:.08em;margin-bottom:4px}
.cb-title{font-size:15px;font-weight:700;color:var(--wh);letter-spacing:.04em}
.cb-gifts{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:6px}
.cb-gift{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.18);border-radius:20px;padding:3px 10px;font-size:11px;color:var(--wh)}
.cb-gift::before{content:'✦';font-size:8px;opacity:.8}
.cb-deadline{font-size:11px;color:rgba(255,255,255,.75);margin-top:4px}

/* ── 2. HERO / PAIN導入 ── */
.hero{min-height:100vh;background:var(--tb);position:relative;display:flex;flex-direction:column;justify-content:center;padding:80px 20px 80px;overflow:hidden}
.hbg1{position:absolute;width:480px;height:480px;border-radius:50%;background:var(--tq);opacity:.06;top:-160px;right:-100px}
.hbg2{position:absolute;width:260px;height:260px;border-radius:50%;background:var(--tql);opacity:.05;bottom:-50px;left:-50px}
.hgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(96,199,213,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(96,199,213,.04) 1px,transparent 1px);background-size:52px 52px}
.hi{position:relative;max-width:640px;margin:0 auto;width:100%}
.eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(96,199,213,.1);border:1px solid rgba(96,199,213,.25);border-radius:40px;padding:5px 14px;font-size:11px;color:var(--tql);letter-spacing:.08em;margin-bottom:24px;animation:fu .8s ease both}
.eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--tql);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.hero-q{font-size:clamp(13px,3vw,16px);color:rgba(255,255,255,.5);letter-spacing:.04em;margin-bottom:12px;animation:fu .8s .05s ease both}
h1.hero-catch{font-family:'Shippori Mincho',serif;font-size:clamp(38px,10vw,62px);font-weight:600;line-height:1.25;color:var(--wh);margin-bottom:8px;animation:fu .8s .1s ease both}
.hero-sub{font-family:'Shippori Mincho',serif;font-size:clamp(16px,4vw,22px);color:rgba(255,255,255,.6);margin-bottom:28px;animation:fu .8s .18s ease both}
.hero-desc{font-size:13px;color:rgba(255,255,255,.45);line-height:2;margin-bottom:40px;max-width:460px;animation:fu .8s .26s ease both}
.btn-hero{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--tq);color:var(--wh);font-size:15px;font-weight:500;padding:17px 34px;border-radius:60px;border:none;cursor:pointer;transition:all .22s;text-decoration:none;max-width:340px;animation:fu .8s .34s ease both}
.btn-hero:hover{background:#1c9eb2;transform:translateY(-2px)}
.hero-note{font-size:11px;color:rgba(255,255,255,.25);margin-top:10px;animation:fu .8s .4s ease both}
.scroll-ind{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:4px}
.sline{width:1px;height:32px;background:linear-gradient(to bottom,rgba(96,199,213,.45),transparent);animation:sd 2s ease infinite}
@keyframes sd{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
.stxt{font-size:9px;letter-spacing:.14em;color:rgba(255,255,255,.2)}

/* ── 3. 数字で痛みを可視化 ── */
.nanpin-card{background:var(--tb);border-radius:16px;padding:28px 20px;position:relative;overflow:hidden;margin-bottom:16px}
.nanpin-card::before{content:'';position:absolute;top:-40px;right:-40px;width:140px;height:140px;border-radius:50%;background:rgba(247,114,97,.08)}
.nanpin-label{font-size:10px;letter-spacing:.1em;color:rgba(255,255,255,.35);margin-bottom:8px;font-weight:500}
.nanpin-scenario{display:flex;flex-direction:column;gap:0}
.ns-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.07)}
.ns-row:last-child{border-bottom:none}
.ns-left{display:flex;flex-direction:column;gap:2px}
.ns-action{font-size:12px;color:rgba(255,255,255,.5)}
.ns-price{font-family:'Shippori Mincho',serif;font-size:18px;font-weight:500;color:var(--wh)}
.ns-right{text-align:right}
.ns-result{font-size:11px;color:rgba(255,255,255,.35)}
.ns-loss{font-family:'Shippori Mincho',serif;font-size:16px;font-weight:500;color:var(--og)}
.nanpin-total{background:rgba(247,114,97,.12);border:1px solid rgba(247,114,97,.25);border-radius:10px;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;margin-top:12px}
.nt-label{font-size:12px;color:rgba(255,255,255,.5)}
.nt-val{font-family:'Shippori Mincho',serif;font-size:22px;font-weight:600;color:var(--og)}
.insight-note{padding:20px;background:rgba(37,178,199,.07);border-radius:12px;border-left:2px solid var(--tql)}
.insight-note p{font-size:13px;color:rgba(255,255,255,.6);line-height:1.9}
.insight-note .hl{color:var(--tql);font-weight:500}

/* ── 4. 準備ゼロシミュ ── */
.sim-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.sim-card{border-radius:14px;padding:20px 16px;border:1px solid var(--bd)}
.sim-card.bad{border-color:rgba(247,114,97,.3);background:rgba(247,114,97,.04)}
.sim-card.good{border-color:rgba(37,178,199,.3);background:rgba(37,178,199,.04)}
.sim-tag{font-size:10px;font-weight:500;letter-spacing:.06em;padding:2px 8px;border-radius:20px;margin-bottom:10px;display:inline-block}
.sim-tag.bad{background:rgba(247,114,97,.12);color:#993C1D}
.sim-tag.good{background:var(--tqp);color:var(--tq)}
.sim-title{font-size:14px;font-weight:500;color:var(--tb);margin-bottom:8px}
.sim-items{display:flex;flex-direction:column;gap:5px}
.sim-item{font-size:12px;color:var(--stone);display:flex;align-items:flex-start;gap:5px;line-height:1.5}
.sim-item::before{content:'';width:4px;height:4px;border-radius:50%;flex-shrink:0;margin-top:6px}
.sim-card.bad .sim-item::before{background:#D85A30}
.sim-card.good .sim-item::before{background:var(--tq)}
.sim-resolve{padding:18px;background:var(--iv);border-radius:12px;text-align:center}
.sim-resolve p{font-size:13px;color:var(--stone);line-height:1.8}
.sim-resolve .hl{color:var(--tb);font-weight:500}

/* ── 5. PAIN深化 ── */
.pain-deep{text-align:center;padding:64px 20px;background:var(--tb);position:relative;overflow:hidden}
.pain-deep::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(247,114,97,.06) 0%,transparent 70%)}
.pd-in{position:relative;max-width:560px;margin:0 auto}
.pd-q{font-family:'Shippori Mincho',serif;font-size:clamp(24px,6vw,38px);font-weight:500;color:var(--wh);line-height:1.5;margin-bottom:20px}
.pd-q .red{color:#F0997B}
.pd-sub{font-size:13px;color:rgba(255,255,255,.45);line-height:1.9}

/* ── 6. BRIDGE ── */
.bridge-box{background:var(--tqp);border-radius:16px;padding:28px 22px;border:1px solid rgba(37,178,199,.2);text-align:center}
.bridge-box h2{font-family:'Shippori Mincho',serif;font-size:clamp(18px,4.5vw,26px);font-weight:500;color:var(--tb);line-height:1.6;margin-bottom:14px}
.bridge-box h2 .ac{color:var(--tq)}
.bridge-box p{font-size:13px;color:var(--stone);line-height:1.9}

/* ── 7・8 CONTRAST ── */
.contrast-cards{display:flex;flex-direction:column;gap:12px;margin-top:28px}
.cc{border-radius:16px;padding:24px 20px;border:1px solid var(--bd);background:var(--wh)}
.cc.good{border-color:rgba(37,178,199,.3);background:rgba(37,178,199,.02)}
.cc.bad{border-color:rgba(247,114,97,.3);background:rgba(247,114,97,.02)}
.cc-head{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.cc-avatar{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.cc-avatar.good{background:var(--tqp)}
.cc-avatar.bad{background:#FAECE7}
.cc-info{}
.cc-name{font-size:14px;font-weight:500;color:var(--tb)}
.cc-meta{font-size:11px;color:var(--stone)}
.cc-tag{display:inline-block;font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;margin-bottom:8px}
.cc-tag.good{background:var(--tqp);color:var(--tq)}
.cc-tag.bad{background:#FAECE7;color:#993C1D}
.cc-items{display:flex;flex-direction:column;gap:6px}
.cc-item{font-size:13px;color:var(--stone);display:flex;align-items:flex-start;gap:8px;line-height:1.6}
.cc-item-icon{font-size:12px;flex-shrink:0;margin-top:2px}
.cc-result{margin-top:14px;padding:12px 14px;border-radius:10px;font-size:13px;font-weight:500;line-height:1.6}
.cc-result.good{background:var(--tqp);color:#0F6E56}
.cc-result.bad{background:#FAECE7;color:#993C1D}

/* ── 9 COMPARE TABLE ── */
.compare-table{width:100%;border-collapse:collapse;margin-top:28px;font-size:13px}
.compare-table th{padding:12px 10px;background:var(--tb);color:rgba(255,255,255,.7);font-weight:500;font-size:11px;letter-spacing:.06em;border:1px solid rgba(255,255,255,.08)}
.compare-table th.col-good{color:var(--tql)}
.compare-table th.col-bad{color:#F0997B}
.compare-table td{padding:12px 10px;border:1px solid var(--bd);line-height:1.5;vertical-align:top}
.compare-table td.axis{font-weight:500;font-size:11px;color:var(--stone);background:var(--iv)}
.compare-table td.good{color:#0F6E56;background:rgba(37,178,199,.03)}
.compare-table td.bad{color:#993C1D;background:rgba(247,114,97,.03)}

/* ── 10 GRAPH / 複利 ── */
.graph-wrap{margin-top:28px;background:var(--tb);border-radius:16px;padding:28px 20px}
.graph-label{font-size:10px;letter-spacing:.1em;color:rgba(255,255,255,.35);margin-bottom:16px;font-weight:500}
.graph-bars{display:flex;flex-direction:column;gap:14px}
.gbar-row{display:flex;align-items:center;gap:10px}
.gbar-name{font-size:11px;color:rgba(255,255,255,.5);width:60px;flex-shrink:0;line-height:1.4;text-align:right}
.gbar-track{flex:1;height:32px;background:rgba(255,255,255,.06);border-radius:6px;overflow:hidden;position:relative}
.gbar-fill{height:100%;border-radius:6px;display:flex;align-items:center;padding-left:10px;font-family:'Shippori Mincho',serif;font-size:14px;font-weight:500;color:var(--wh);transition:width 1.2s ease}
.gbar-fill.tq{background:var(--tq)}
.gbar-fill.og{background:var(--og)}
.gbar-fill.stone{background:var(--stone)}
.graph-note{margin-top:16px;font-size:11px;color:rgba(255,255,255,.3);line-height:1.7}

/* ── 11 WHY ── */
.why-cards{display:flex;flex-direction:column;gap:10px;margin-top:28px}
.why-card{display:flex;gap:14px;padding:18px;border-radius:12px;border:1px solid var(--bd);background:var(--wh)}
.why-num{font-family:'Shippori Mincho',serif;font-size:28px;font-weight:400;color:var(--tql);opacity:.4;flex-shrink:0;line-height:1;width:32px;padding-top:4px}
.why-ttl{font-size:14px;font-weight:500;color:var(--tb);margin-bottom:4px}
.why-desc{font-size:12px;color:var(--stone);line-height:1.75}

/* ── 12 キャンペーン再訴求 ── */
.campaign2{background:var(--og);border-radius:16px;padding:28px 22px;text-align:center;position:relative;overflow:hidden}
.campaign2::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.06)}
.c2-tag{display:inline-block;background:rgba(255,255,255,.2);border-radius:20px;font-size:10px;color:var(--wh);font-weight:500;padding:2px 10px;letter-spacing:.08em;margin-bottom:10px}
.c2-title{font-family:'Shippori Mincho',serif;font-size:clamp(18px,4.5vw,24px);color:var(--wh);font-weight:500;line-height:1.5;margin-bottom:12px}
.c2-gifts{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
.c2-gift{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);border-radius:10px;padding:8px 12px;font-size:12px;color:var(--wh)}
.c2-gift::before{content:'🎁';font-size:14px}
.btn-og{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--wh);color:var(--og);font-size:14px;font-weight:700;padding:15px 32px;border-radius:60px;border:none;cursor:pointer;text-decoration:none;transition:all .22s;letter-spacing:.04em;width:100%;max-width:320px}
.btn-og:hover{transform:translateY(-2px)}

/* ── 13 講座内容 ── */
.contents-list{display:flex;flex-direction:column;gap:0;margin-top:28px}
.cont-item{display:flex;gap:14px;padding:18px 0;border-bottom:1px solid var(--bd)}
.cont-item:last-child{border-bottom:none}
.cont-n{font-family:'Shippori Mincho',serif;font-size:30px;font-weight:400;color:var(--tql);opacity:.4;flex-shrink:0;line-height:1;width:36px;padding-top:4px}
.cont-tag{display:inline-block;background:var(--tqp);color:var(--tq);font-size:10px;font-weight:500;letter-spacing:.06em;padding:2px 8px;border-radius:20px;margin-bottom:5px}
.cont-ttl{font-size:15px;font-weight:500;color:var(--tb);margin-bottom:4px}
.cont-desc{font-size:12px;color:var(--stone);line-height:1.75}

/* ── 14 URGENCY ── */
.urgency-box{background:var(--tb);border-radius:16px;padding:28px 22px;text-align:center;border:1px solid rgba(96,199,213,.15);position:relative;overflow:hidden}
.urgency-box::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(37,178,199,.07) 0%,transparent 70%)}
.urg-in{position:relative}
.urg-icon{font-size:28px;margin-bottom:12px}
.urg-title{font-family:'Shippori Mincho',serif;font-size:clamp(18px,4.5vw,24px);color:var(--wh);line-height:1.5;margin-bottom:12px}
.urg-title .ac{color:var(--tql)}
.urg-desc{font-size:13px;color:rgba(255,255,255,.45);line-height:1.9}

/* ── 15 ABCash紹介 ── */
.trust-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:28px}
.trust-stat{background:var(--iv);border-radius:14px;padding:20px 16px;text-align:center}
.ts-num{font-family:'Shippori Mincho',serif;font-size:32px;font-weight:500;color:var(--tq);line-height:1.2;margin-bottom:4px}
.ts-unit{font-size:14px;font-weight:400}
.ts-label{font-size:11px;color:var(--stone);line-height:1.4}

/* ── 16 メディア ── */
.media-logos{display:flex;flex-wrap:wrap;gap:8px;margin-top:24px;justify-content:center}
.media-logo{background:var(--iv);border-radius:10px;padding:10px 16px;font-size:11px;font-weight:500;color:var(--stone);letter-spacing:.04em;border:1px solid var(--bd)}

/* ── 17 Before & After ── */
.baa-cards{display:flex;flex-direction:column;gap:12px;margin-top:28px}
.baa-card{border-radius:16px;padding:22px 18px;border:1px solid var(--bd);background:var(--wh)}
.baa-head{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.baa-avatar{width:44px;height:44px;border-radius:50%;background:var(--tqp);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.baa-name{font-size:14px;font-weight:500;color:var(--tb)}
.baa-meta{font-size:11px;color:var(--stone)}
.baa-change{display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center}
.baa-before,.baa-after{padding:10px 12px;border-radius:10px;font-size:12px;line-height:1.6}
.baa-before{background:#FAECE7;color:#712B13}
.baa-after{background:var(--tqp);color:#0F6E56}
.baa-arrow{font-size:18px;color:var(--tql);text-align:center}
.baa-label{font-size:10px;font-weight:500;letter-spacing:.06em;margin-bottom:5px}
.baa-label.bf{color:#993C1D}
.baa-label.af{color:var(--tq)}

/* ── 18・19・20 REASON ── */
.reason-card{border-radius:16px;padding:28px 22px;margin-bottom:12px;border:1px solid var(--bd);background:var(--wh)}
.reason-num{font-size:10px;font-weight:500;letter-spacing:.1em;color:var(--tq);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.reason-num::before{content:'';width:14px;height:1px;background:var(--tq)}
.reason-ttl{font-family:'Shippori Mincho',serif;font-size:clamp(18px,4.5vw,24px);font-weight:500;color:var(--tb);line-height:1.5;margin-bottom:12px}
.reason-desc{font-size:13px;color:var(--stone);line-height:1.9}
.reason-visual{margin-top:16px;background:var(--iv);border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:6px}
.rv-row{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--tb)}
.rv-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.rv-dot-tq{background:var(--tq)}
.rv-dot-og{background:var(--og)}
.rv-dot-st{background:#B4B2A9}
.rv-dot-new{background:var(--tq);border:2px solid var(--tql)}
.rv-badge{background:var(--tq);color:var(--wh);font-size:9px;font-weight:500;padding:1px 6px;border-radius:10px;margin-left:4px}
.etf-pill-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.etf-pill{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:500;border:1px solid transparent}
.ep-pink{background:#FBEAF0;color:#72243E;border-color:#ED93B1}
.ep-blue{background:#E6F1FB;color:#0C447C;border-color:#85B7EB}
.ep-amber{background:#FAEEDA;color:#633806;border-color:#EF9F27}

/* ── CTA FINAL ── */
.cta-final{padding:80px 20px;background:var(--tb);text-align:center;position:relative;overflow:hidden}
.cta-final::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(37,178,199,.09) 0%,transparent 70%)}
.cf-in{position:relative;max-width:460px;margin:0 auto}
.cf-lbl{font-size:10px;letter-spacing:.16em;color:var(--tql);margin-bottom:16px}
.cf-h{font-family:'Shippori Mincho',serif;font-size:clamp(22px,6vw,34px);font-weight:500;color:var(--wh);line-height:1.55;margin-bottom:14px}
.cf-h .ac{color:var(--tql)}
